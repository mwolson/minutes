# Minutes Demo — Terminal Recording
# Produces: docs/assets/demo.gif
# Run: vhs docs/assets/demo.tape

Output docs/assets/demo.gif

Set Shell "bash"
Set FontSize 14
Set Width 800
Set Height 400
Set Padding 20
Set Theme "Catppuccin Mocha"
Set TypingSpeed 50ms

# Show the demo command
Type "minutes demo"
Enter
Sleep 3s

# Show search
Type "minutes search 'pricing'"
Enter
Sleep 3s

# Show action items
Type "minutes actions"
Enter
Sleep 3s
